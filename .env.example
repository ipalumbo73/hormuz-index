# Database
DATABASE_URL=postgresql+asyncpg://georisk:georisk@localhost:5432/georisk
DATABASE_URL_SYNC=postgresql://georisk:georisk@localhost:5432/georisk
POSTGRES_USER=georisk
POSTGRES_PASSWORD=georisk
POSTGRES_DB=georisk

# Redis
REDIS_URL=redis://localhost:6379/0

# API Keys
NEWSDATA_API_KEY=your_newsdata_api_key_here

# App
SECRET_KEY=change-me-in-production
API_PREFIX=/api/v1
DEBUG=true
LOG_LEVEL=INFO

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Ingestion schedule (seconds)
GDELT_INTERVAL=900
NEWSDATA_INTERVAL=600
RSS_INTERVAL=300
RECOMPUTE_INTERVAL=600

# Alert channels (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=
